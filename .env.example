# =====================================================================
# Ajo Datuak — Contoh environment variables (root)
# Salin file ini ke `.env.local` di dalam masing-masing app yang butuh.
# JANGAN isi secret asli di sini. JANGAN commit .env.local.
# Lihat CLAUDE.md §7.4.
# =====================================================================

# --- Supabase (dipakai kedua app) ---
# Aman diekspos ke client (NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side ONLY — JANGAN beri prefix NEXT_PUBLIC_.
# Dipakai untuk webhook (admin) & insert order tepercaya (customer /api/checkout).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Midtrans (server-side ONLY) ---
# Pakai Sandbox Server Key. JANGAN ekspos ke client.
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
# Client key (jika perlu Snap.js di kemudian hari)
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
# false = Sandbox, true = Production
MIDTRANS_IS_PRODUCTION=false
