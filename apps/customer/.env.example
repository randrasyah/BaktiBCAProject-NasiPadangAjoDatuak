# =====================================================================
# Customer App — contoh env. Salin ke `apps/customer/.env.local`.
# JANGAN commit .env.local. Lihat CLAUDE.md §7.4.
# =====================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side ONLY — dipakai /api/checkout untuk insert order tepercaya.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Midtrans (server-side ONLY — dipakai /api/checkout charge) ---
# Server Key Sandbox. Sandbox bisa berawalan "Mid-server-" (bukan selalu "SB-Mid-").
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
