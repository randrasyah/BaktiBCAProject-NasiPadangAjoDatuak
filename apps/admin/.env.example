# =====================================================================
# Admin App — contoh env. Salin ke `apps/admin/.env.local`.
# JANGAN commit .env.local. Lihat CLAUDE.md §7.4.
# =====================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side ONLY — dipakai webhook Midtrans untuk update status 'paid'.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Midtrans (server-side ONLY — dipakai webhook untuk verifikasi signature) ---
# Pakai Server Key Sandbox YANG SAMA dengan apps/customer (signature diverifikasi
# dengan server key yang dipakai saat charge). Sandbox bisa berawalan "Mid-server-".
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
